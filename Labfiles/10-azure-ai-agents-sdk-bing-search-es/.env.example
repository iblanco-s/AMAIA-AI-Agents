# Azure AI Project Configuration
# Copia este archivo a la raíz del proyecto como .env y rellena los valores

# Azure AI Foundry Project Endpoint
# Ejemplo: https://tu-proyecto.cognitiveservices.azure.com/
PROJECT_ENDPOINT=

# Azure AI Model Deployment Name
# Ejemplo: gpt-4, gpt-4o, etc.
MODEL_DEPLOYMENT_NAME=

# Bing Search Connection ID
# Obtén este ID desde Azure AI Foundry Portal > Settings > Connections
# Después de crear una conexión de tipo "Bing Search"
BING_CONNECTION_ID=
